{
    "manifest_version": 3,
    "name": "BiClock",
    "version": "1.0",
    "description": "全屏播放Bilibili视频时，在视频顶部显示当前时间",
    "icons": {
        "200": "icons/clock.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "200": "icons/clock.png"
        }
    },
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": ["*://*.bilibili.com/video/*", "*://*.bilibili.com/bangumi/*"],
            "js": ["biclock.js"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "clock@example.com"
        }
    }
}
